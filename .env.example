# OraGraphRAG configuration overrides.
#
# Config is loaded from defaults < config.yaml < these env vars.
# Every value in config.yaml can be overridden via OGR__SECTION__KEY using
# double underscores between section path components.

# Oracle 23ai Free
OGR__ORACLE__USERNAME=ORAGRAPH
OGR__ORACLE__PASSWORD=Welcome12345*
OGR__ORACLE__DSN=localhost:1521/FREEPDB1

# LLM provider (oci_grok | ollama | openai_compat)
# OGR__LLM__PROVIDER=ollama

# Retrieval knobs
# OGR__RETRIEVAL__AMPLITUDE__ALPHA=8.0

# Read by the OCI Python SDK directly, not by Config:
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
